#!/bin/bash
# NOOBS ZIVUDP Dashboard - Colorful Edition

CONFIG="/etc/zivpn/config.json"
DB="/etc/zivpn/users.db"

# --- Colors ---
C="\e[1;36m"
G="\e[1;32m"
R="\e[1;31m"
Y="\e[1;33m"
M="\e[1;35m"
B="\e[1;34m"
NC="\e[0m"
BOLD="\e[1m"

# --- Auto-install jq if missing ---
if ! command -v jq &>/dev/null; then
    echo -e "${Y}Installing jq...${NC}"
    apt-get install -y jq -qq &>/dev/null
fi

# --- Fetch System Info ---
GEO=$(curl -4 -s --max-time 10 "https://ipapi.co/json/" 2>/dev/null)
IP=$(echo "$GEO"      | grep -oP '"ip":\s*"\K[^"]+')
CITY=$(echo "$GEO"    | grep -oP '"city":\s*"\K[^"]+')
COUNTRY=$(echo "$GEO" | grep -oP '"country_name":\s*"\K[^"]+')
ISP=$(echo "$GEO"     | grep -oP '"org":\s*"\K[^"]+')
OS_INFO=$(grep "PRETTY_NAME" /etc/os-release | cut -d '"' -f 2)

[ -z "$IP" ]      && IP="N/A"
[ -z "$CITY" ]    && CITY="Unknown"
[ -z "$COUNTRY" ] && COUNTRY="Unknown"
[ -z "$ISP" ]     && ISP="Unknown"

