    echo -e "${G}${BOLD}  ╚═╝  ╚══╝ ╚═════╝  ╚═════╝ ╚═════╝ ╚══════╝                    ${NC}"
    echo -e "${Y}${BOLD}  ███████╗██╗██╗   ██╗██╗   ██╗██████╗ ██████╗                    ${NC}"
    echo -e "${Y}${BOLD}  ╚════██║██║██║   ██║██║   ██║██╔══██╗██╔══██╗                   ${NC}"
    echo -e "${Y}${BOLD}      ██╔╝██║██║   ██║██║   ██║██║  ██║██████╔╝                   ${NC}"
    echo -e "${Y}${BOLD}     ██╔╝ ██║╚██╗ ██╔╝██║   ██║██║  ██║██╔═══╝                    ${NC}"
    echo -e "${Y}${BOLD}    ███████╗╚████╔╝  ╚██████╔╝██████╔╝██║                        ${NC}"
    echo -e "${Y}${BOLD}    ╚══════╝ ╚═══╝    ╚═════╝ ╚═════╝ ╚═╝                        ${NC}"
