    echo -e "${G}${BOLD}  в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ           ${NC}"
    echo -e "${G}${BOLD}  в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•қ в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•қ            ${NC}"
    echo -e "${G}${BOLD}  в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘     в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘                ${NC}"
    echo -e "${G}${BOLD}   в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ      в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ   ${Y}NOOBS ZIVUDP    ${NC}"
    echo -e "${C}${BOLD}================================================================${NC}"
    echo -e "${M} рҹ‘‘ Admin    :${NC} @Ardvak"
    echo -e "${M} рҹ’» OS       :${NC} ${OS_INFO}"
    echo -e "${M} рҹҢҚ Server   :${NC} ${IP} (${CITY}, ${COUNTRY})"
    echo -e "${M} рҹҸў ISP      :${NC} ${ISP}"
    echo -e "${M} вҸ° Time     :${NC} ${DATE_TIME}"
    echo -e "${C}${BOLD}================================================================${NC}"
}

